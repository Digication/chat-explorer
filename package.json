{
  "name": "chat-explorer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "node --watch --watch-path=./src/server --import @swc-node/register/esm-register ./src/server/index.ts",
    "dev:client": "vite",
    "dev:full": "concurrently \"pnpm dev\" \"pnpm dev:client\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "graphql-codegen",
    "migration:generate": "typeorm migration:generate -d src/server/data-source.ts",
    "migration:run": "typeorm migration:run -d src/server/data-source.ts",
    "e2e": "npx playwright test",
    "e2e:headed": "npx playwright test --headed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@apollo/client": "^4.1.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/generative-ai": "^0.24.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@react-pdf/renderer": "^4.3.2",
    "@sendgrid/mail": "^8.1.6",
    "better-auth": "^1.6.2",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.18.1",
    "json2csv": "6.0.0-alpha.2",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.2",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "2.0.0-rc.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@playwright/test": "^1.59.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.21",
    "@swc/helpers": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0",
      "defu": ">=6.1.5"
    }
  }
}
